{
  "name": "fukusa",
  "displayName": "Fukusa",
  "description": "Fukusa: N-way diff viewer that keeps the main compare surface in native VS Code editors",
  "version": "0.0.1",
  "publisher": "multidiffviewer",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/horiyamayoh/MultiDiffViewer#readme",
  "bugs": {
    "url": "https://github.com/horiyamayoh/MultiDiffViewer/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/horiyamayoh/MultiDiffViewer.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "fukusa",
    "git",
    "svn",
    "diff",
    "history",
    "blame"
  ],
  "extensionKind": [
    "workspace"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [
    "onCommand:multidiff.browseRevisions",
    "onCommand:multidiff.browseRevisionsSingleTab",
    "onCommand:multidiff.changePairProjection",
    "onCommand:multidiff.closeActiveSession",
    "onCommand:multidiff.expandAllCollapsedGaps",
    "onCommand:multidiff.openActiveSessionSnapshot",
    "onCommand:multidiff.openActiveSessionPairDiff",
    "onCommand:multidiff.resetExpandedGaps",
    "onCommand:multidiff.shiftWindowLeft",
    "onCommand:multidiff.shiftWindowRight",
    "onCommand:multidiff.switchCompareSurface",
    "onCommand:multidiff.toggleBlameHeatmap",
    "onCommand:multidiff.toggleCollapseUnchanged",
    "onCommand:multidiff.cache.warmCurrentFile",
    "onCommand:multidiff.cache.clearCurrentRepo",
    "onCommand:multidiff.cache.clearAll",
    "onFileSystem:multidiff",
    "onView:multidiff.sessions",
    "onView:multidiff.cache"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "multidiff.browseRevisions",
        "title": "Fukusa: Browse Revisions",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.browseRevisionsSingleTab",
        "title": "Fukusa: Browse Revisions (Single-Tab)",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.changePairProjection",
        "title": "Fukusa: Change Pair Projection",
        "category": "Fukusa",
        "enablement": "multidiff.canChangePairProjection"
      },
      {
        "command": "multidiff.closeActiveSession",
        "title": "Fukusa: Close Active Session",
        "category": "Fukusa",
        "enablement": "multidiff.hasActiveSession"
      },
      {
        "command": "multidiff.expandAllCollapsedGaps",
        "title": "Fukusa: Expand All Collapsed Gaps",
        "category": "Fukusa",
        "enablement": "multidiff.collapseUnchangedActive && multidiff.hasCollapsedGaps"
      },
      {
        "command": "multidiff.openActiveSessionSnapshot",
        "title": "Fukusa: Open Active Session Snapshot",
        "category": "Fukusa",
        "enablement": "multidiff.hasActiveSnapshot"
      },
      {
        "command": "multidiff.openActiveSessionPairDiff",
        "title": "Fukusa: Open Active Session Pair Diff",
        "category": "Fukusa",
        "enablement": "multidiff.hasActivePair"
      },
      {
        "command": "multidiff.shiftWindowLeft",
        "title": "Fukusa: Shift Window Left",
        "category": "Fukusa",
        "enablement": "multidiff.canShiftWindowLeft"
      },
      {
        "command": "multidiff.shiftWindowRight",
        "title": "Fukusa: Shift Window Right",
        "category": "Fukusa",
        "enablement": "multidiff.canShiftWindowRight"
      },
      {
        "command": "multidiff.resetExpandedGaps",
        "title": "Fukusa: Reset Expanded Gaps",
        "category": "Fukusa",
        "enablement": "multidiff.collapseUnchangedActive && multidiff.hasExpandedGaps"
      },
      {
        "command": "multidiff.switchCompareSurface",
        "title": "Fukusa: Switch Compare Surface",
        "category": "Fukusa",
        "enablement": "multidiff.hasActiveSession"
      },
      {
        "command": "multidiff.toggleBlameHeatmap",
        "title": "Fukusa: Toggle Blame Heatmap",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.toggleCollapseUnchanged",
        "title": "Fukusa: Toggle Collapse Unchanged",
        "category": "Fukusa",
        "enablement": "multidiff.hasActiveSession"
      },
      {
        "command": "multidiff.cache.warmCurrentFile",
        "title": "Fukusa: Warm Cache for Current File",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.cache.clearCurrentRepo",
        "title": "Fukusa: Clear Cache for Current Repository",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.cache.clearAll",
        "title": "Fukusa: Clear All Cache",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.revealSession",
        "title": "Reveal Session",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.changePairProjection",
        "title": "Change Pair Projection",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.closeSession",
        "title": "Close Session",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.expandAllCollapsedGaps",
        "title": "Expand All Collapsed Gaps",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.openSessionPairDiff",
        "title": "Open Session Pair Diff",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.openSessionSnapshot",
        "title": "Open Session Snapshot",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.resetExpandedGaps",
        "title": "Reset Expanded Gaps",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.scrollAlignedUp",
        "title": "Scroll Aligned Up",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.scrollAlignedDown",
        "title": "Scroll Aligned Down",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.shiftWindowLeft",
        "title": "Shift Window Left",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.shiftWindowRight",
        "title": "Shift Window Right",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.switchCompareSurface",
        "title": "Switch Compare Surface",
        "category": "Fukusa"
      },
      {
        "command": "multidiff.internal.toggleCollapseUnchanged",
        "title": "Toggle Collapse Unchanged",
        "category": "Fukusa"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "multidiff.internal.revealSession",
          "when": "false"
        },
        {
          "command": "multidiff.internal.changePairProjection",
          "when": "false"
        },
        {
          "command": "multidiff.internal.closeSession",
          "when": "false"
        },
        {
          "command": "multidiff.internal.expandAllCollapsedGaps",
          "when": "false"
        },
        {
          "command": "multidiff.internal.openSessionPairDiff",
          "when": "false"
        },
        {
          "command": "multidiff.internal.openSessionSnapshot",
          "when": "false"
        },
        {
          "command": "multidiff.internal.resetExpandedGaps",
          "when": "false"
        },
        {
          "command": "multidiff.internal.scrollAlignedUp",
          "when": "false"
        },
        {
          "command": "multidiff.internal.scrollAlignedDown",
          "when": "false"
        },
        {
          "command": "multidiff.internal.shiftWindowLeft",
          "when": "false"
        },
        {
          "command": "multidiff.internal.shiftWindowRight",
          "when": "false"
        },
        {
          "command": "multidiff.internal.switchCompareSurface",
          "when": "false"
        },
        {
          "command": "multidiff.internal.toggleCollapseUnchanged",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "multidiff.internal.revealSession",
          "group": "inline@1",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/"
        },
        {
          "command": "multidiff.internal.switchCompareSurface",
          "group": "inline@2",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/"
        },
        {
          "command": "multidiff.internal.closeSession",
          "group": "inline@3",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/"
        },
        {
          "command": "multidiff.internal.changePairProjection",
          "group": "navigation@1",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )pair-projectable( |$)/"
        },
        {
          "command": "multidiff.internal.openSessionSnapshot",
          "group": "navigation@1.1",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )has-active-snapshot( |$)/"
        },
        {
          "command": "multidiff.internal.openSessionPairDiff",
          "group": "navigation@1.2",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )has-active-pair( |$)/"
        },
        {
          "command": "multidiff.internal.toggleCollapseUnchanged",
          "group": "navigation@2",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/"
        },
        {
          "command": "multidiff.internal.shiftWindowLeft",
          "group": "navigation@2.1",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )can-shift-window-left( |$)/"
        },
        {
          "command": "multidiff.internal.shiftWindowRight",
          "group": "navigation@2.2",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )can-shift-window-right( |$)/"
        },
        {
          "command": "multidiff.internal.expandAllCollapsedGaps",
          "group": "navigation@3",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )collapse-active( |$)/ && viewItem =~ /(^| )has-collapsed-gaps( |$)/"
        },
        {
          "command": "multidiff.internal.resetExpandedGaps",
          "group": "navigation@4",
          "when": "view == multidiff.sessions && viewItem =~ /(^| )session( |$)/ && viewItem =~ /(^| )collapse-active( |$)/ && viewItem =~ /(^| )has-expanded-gaps( |$)/"
        },
        {
          "command": "multidiff.internal.openSessionSnapshot",
          "group": "inline@1",
          "when": "view == multidiff.sessions && viewItem == snapshot"
        }
      ],
      "explorer/context": [
        {
          "command": "multidiff.browseRevisions",
          "group": "3_compare@1",
          "when": "resourceScheme == file"
        },
        {
          "command": "multidiff.browseRevisionsSingleTab",
          "group": "3_compare@2",
          "when": "resourceScheme == file"
        }
      ]
    },
    "keybindings": [
      {
        "command": "multidiff.internal.scrollAlignedUp",
        "key": "ctrl+up",
        "when": "resourceScheme == multidiff-session-doc && editorTextFocus"
      },
      {
        "command": "multidiff.internal.scrollAlignedDown",
        "key": "ctrl+down",
        "when": "resourceScheme == multidiff-session-doc && editorTextFocus"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "multidiff.sessions",
          "name": "Fukusa Sessions"
        },
        {
          "id": "multidiff.cache",
          "name": "Fukusa Cache"
        }
      ]
    },
    "configuration": {
      "title": "Fukusa",
      "properties": {
        "multidiff.blame.mode": {
          "type": "string",
          "default": "age",
          "enum": [
            "age"
          ],
          "description": "Blame heatmap mode."
        },
        "multidiff.blame.showOverviewRuler": {
          "type": "boolean",
          "default": true,
          "description": "Show blame colors in the overview ruler."
        },
        "multidiff.cache.maxSizeMb": {
          "type": "number",
          "default": 512,
          "minimum": 16,
          "description": "Maximum in-memory cache size in MiB."
        },
        "multidiff.snapshot.openMode": {
          "type": "string",
          "default": "virtual",
          "enum": [
            "virtual",
            "tempFile"
          ],
          "markdownDescription": "How Fukusa opens raw revision snapshots. `virtual` keeps the synthetic `multidiff:` URI, while `tempFile` mirrors the snapshot to a temporary file for compatibility-sensitive workflows."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\" && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ./out/test/runTest.js --grep \"^Unit:\"",
    "test:integration": "node ./out/test/runIntegration.js",
    "lint": "eslint src --ext .ts",
    "package:vsix": "vsce package --pre-release",
    "publish:prerelease": "vsce publish --pre-release",
    "publish:release": "vsce publish"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/sinon": "^17.0.3",
    "@types/uuid": "^9.0.7",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.57.1",
    "mocha": "^10.2.0",
    "sinon": "^17.0.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "fast-xml-parser": "^5.5.5",
    "lru-cache": "^10.1.0",
    "uuid": "^9.0.0"
  }
}
